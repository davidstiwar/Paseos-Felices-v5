# ===============================================
# Paseos Felices v5 - Configuración por Ambiente
# ===============================================
# Copia este archivo a .env y reemplaza los valores

# ===== GOOGLE OAUTH =====
# 1. Obtén estas credenciales en: https://console.cloud.google.com/
# 2. Crea un proyecto OAuth 2.0 para "Aplicación web"
# 3. En "URIs autorizados de redirección", agrega:
#    http://localhost:3000/auth/google/callback
#    http://127.0.0.1:3000/auth/google/callback

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ===== SERVIDOR AUTH =====
AUTH_SERVICE_PORT=8000
AUTH_SERVICE_HOST=0.0.0.0

# ===== BASE DE DATOS =====
# MySQL (development/production):
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/paseos_auth

# ===== TOKEN JWT =====
SECRET_KEY=tu_super_secreto_aqui_cambiar_en_produccion
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3000

# ===== EMAIL (para recuperación de contraseña) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_aqui
SMTP_FROM=noreply@paseofelices.com

# ===== AMBIENTE =====
# development, staging, production
ENVIRONMENT=development
DEBUG=true
